extends ../base

block styles
  link(rel="stylesheet" href="/css/usersAdmin.css")

block content

  a.back-btn(href='/adminDashboard')
    svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
      path(d="M19 12H5M5 12l7 7M5 12l7-7")
    span Back

  .admin-container

    .admin-header
      .admin-header__left
        h1.page-title User Management
        p.page-subtitle Manage members, coaches, and admins
      .admin-actions
        a.admin-btn.admin-btn--outline(href='/createCoach')
          svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
            path(d="M12 5v14M5 12h14")
          span Create Coach

    .admin-stats
      .stat-card
        span.stat-number #{users.length}
        span.stat-label Total Users
      .stat-card
        span.stat-number #{users.filter(u => u.userType === 'coach').length}
        span.stat-label Coaches
      .stat-card
        span.stat-number #{users.filter(u => u.userType === 'admin').length}
        span.stat-label Admins
      .stat-card
        span.stat-number #{users.filter(u => u.userType === 'user').length}
        span.stat-label Members

    if users.length === 0
      .empty-state
        svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
          path(d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75")
        p No users found.
    else
      .table-wrapper
        table.user-table
          thead
            tr
              th Profile
              th User
              th Role
              th Gym Status
              th Actions
          tbody
            each u in users
              tr(data-user-id=u._id)
                td
                  .avatar-wrap
                    if u.pfpUrl
                      img.profile-small(src=u.pfpUrl alt=u.username)
                    else
                      img.profile-small(src="/img/default-user.png" alt="Default")
                    span.status-dot(class=(u.gymStatus && u.gymStatus !== 'offline') ? 'online' : 'offline')

                td
                  .user-info
                    span.user-name #{u.username}
                    span.user-email #{u.email}

                td
                  span.role-badge(class=`role-${u.userType}`) #{u.userType}

                td
                  if u.gymStatus && u.gymStatus !== 'offline'
                    span.gym-status-badge.at-gym
                      span.pulse-dot
                      | #{u.gymStatus === 'logging' ? '🏋️ Logging' : '📍 At Gym'}
                  else
                    span.gym-status-badge.offline Offline

                td
                  .action-btns
                    button.action-btn.attendance-btn(
                      data-user-id=u._id
                      data-username=u.username
                      data-pfp=(u.pfpUrl || '/img/default-user.png')
                      title="View Attendance"
                    )
                      svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
                        path(d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01")
                      span Attendance
                    button.action-btn.delete-user-btn(
                      data-user-id=u._id
                      title="Delete User"
                    )
                      svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
                        path(d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6")
                      span Delete

  //- ATTENDANCE DRAWER
  .drawer-overlay#drawerOverlay
  .attendance-drawer#attendanceDrawer
    .drawer-header
      .drawer-user-info
        img#drawerPfp(src="/img/default-user.png" alt="User")
        .drawer-user-text
          h3#drawerUsername Loading...
          span#drawerSubtitle Gym Attendance History
      button.drawer-close#drawerClose
        span.drawer-close-x ✕

    .drawer-stats
      .d-stat
        span#drawerTotalVisits —
        span Total Visits
      .d-stat
        span#drawerThisMonth —
        span This Month
      .d-stat
        span#drawerAvgDuration —
        span Avg. Duration (min)

    .drawer-body#drawerBody
      .drawer-loading
        .spinner
        p Loading attendance...

block scripts
  script(src="/js/users.js")
