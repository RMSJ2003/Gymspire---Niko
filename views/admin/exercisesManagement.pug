extends ../base

block styles
  link(rel="stylesheet" href="/css/exerciseManagement.css")

block content

  a.back-btn(href='/adminDashboard') ← Back

  .ex-container

    //- Hero header
    .ex-hero
      if user.pfpUrl
        img.ex-hero-avatar(src=user.pfpUrl alt=user.username)
      else
        img.ex-hero-avatar(src="/img/default-user.png" alt="Default")
      .ex-hero-text
        h1 #{title}
        p Logged in as #{user.username}

    //- Import section
    .ex-section-card
      .ex-section-label
        svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24')
          path(d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4')
          polyline(points='17 8 12 3 7 8')
          line(x1='12' y1='3' x2='12' y2='15')
        span Import Exercises
      p
        | Fetches dumbbell exercises from the ExerciseDB API.
        br
        | ⚠️ This process is slow and rate-limited (≈1 min per muscle group).
      button#importExercisesBtn Import Exercises
      p#importMessage

    //- Danger zone
    .ex-section-card
      .ex-section-label
        svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24')
          path(d='M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6')
        span Danger Zone
      p Permanently deletes ALL exercises from the database. This cannot be undone.
      button#deleteAllExercisesBtn Delete ALL Exercises
      p#deleteMessage

    //- Exercise list
    if exercises.length === 0
      p.ex-empty No exercises in the database yet.
    else
      p.ex-list-header #{exercises.length} exercises

      .exercise-list-container
        each exercise in exercises
          .exercise-card
            .exercise-content
              if exercise.gifURL
                img.exercise-gif(src=exercise.gifURL alt=exercise.name)

              .exercise-info
                h3 #{exercise.name}
                p #{exercise.target}

                if exercise.instructions && exercise.instructions.length
                  h4 Instructions
                  ul
                    each step in exercise.instructions
                      li #{step}

block scripts
  script(src="/js/exercisesManagement.js")
