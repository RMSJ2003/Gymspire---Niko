extends base

block styles
  link(rel="stylesheet" href="/css/createWorkoutPlan.css")

block content
  .top-bar
    if user.userType === "user"
      a.dashboard-btn(href='/dashboard') Dashboard
    if user.userType === "coach"
      a.dashboard-btn(href='/coachDashboard') Dashboard
    if user.userType === "admin"
      a.dashboard-btn(href='/adminDashboard') Dashboard
    a.back-btn(href='javascript:history.back()') Back

  .page-header
    h1 Create Workout Plan
    h2 #{currentUser.username}

  if currentUser.pfpUrl
    img.profile-pic(src=currentUser.pfpUrl alt="Profile Picture" onerror="this.onerror=null;this.src='/img/default-user.png'")
  else
    img.profile-pic(src="/img/default-user.png" alt="Default Profile" onerror="this.onerror=null;this.src='/img/default-user.png'")

  p.section-label Select exercises — multiple per muscle allowed

  .target-grid#targetGrid

  form#createWorkoutPlanForm.hidden

  .update-section
    p.form-message#formMessage
    button(type="submit" form="createWorkoutPlanForm") Create Workout Plan

  //- Target modal — exercise list for a muscle group
  .modal.hidden#targetModal
    .modal-content.large
      .modal-header
        h3#targetTitle
        button#closeTargetModal(type="button" aria-label="Close") ×
      .modal-body
        .exercise-list#targetExerciseList

  //- Exercise info modal — GIF + instructions
  .modal.hidden#exerciseModal
    .modal-content.ex-info-modal
      .modal-header
        span.ex-modal-name#modalExName Exercise
        button#closeModal(type="button" aria-label="Close") ×
      .modal-body
        img#modalGif(alt="Exercise demonstration" loading="lazy")
        button#toggleInstructions(type="button") Show Instructions
        div#modalInstructions.hidden

  script#exercisesData(type="application/json").
    !{JSON.stringify(exercises)}

  script.
    window.exercises = JSON.parse(document.getElementById("exercisesData").textContent)

block scripts
  script(src="/js/createWorkoutPlan.js")
