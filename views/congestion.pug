extends base

block styles
  link(rel="stylesheet" href="/css/congestion.css")

block content

  .top-bar
    a.top-bar__btn(href=user.userType === 'user' ? '/dashboard' : user.userType === 'coach' ? '/coachDashboard' : '/adminDashboard')
      svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
        path(d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z")
        polyline(points="9 22 9 12 15 12 15 22")
      span Dashboard
    a.top-bar__btn.top-bar__btn--ghost(href="javascript:history.back()")
      svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
        path(d="M19 12H5M5 12l7 7M5 12l7-7")
      span Back

  .page-wrap

    .hero
      .logo-wrapper
        .logo-icon
          svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
            path(d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29z")
        span.logo-text GYM#[span SPIRE]
      .logo-divider
      h1.hero__title Gym Congestion
      p.hero__sub Predicted busyness based on real member check-ins

    //- Loading state
    .loading-state#loadingState
      .spinner
      p Analyzing attendance data...

    //- Main content (hidden until loaded)
    .content-wrap.hidden#contentWrap

      //- ── PERSONAL RECOMMENDATION ─────────────────────────
      .recommendation-card#recommendationCard
        .rec-icon 🎯
        .rec-body
          p.rec-title Your best time to visit
          p.rec-time#recTime —
          p.rec-sub#recSub Loading...

      //- ── TODAY'S PREDICTION ──────────────────────────────
      .card
        .section-label
          svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
            circle(cx="12" cy="12" r="10")
            polyline(points="12 6 12 12 16 14")
          span Today's predicted busyness
        .hour-chart#hourChart

      //- ── WEEKLY HEATMAP ──────────────────────────────────
      .card
        .section-label
          svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24")
            rect(x="3" y="4" width="18" height="18" rx="2" ry="2")
            line(x1="16" y1="2" x2="16" y2="6")
            line(x1="8" y1="2" x2="8" y2="6")
            line(x1="3" y1="10" x2="21" y2="10")
          span Quietest days this week
        .day-chart#dayChart

      //- ── STATS ROW ───────────────────────────────────────
      .stats-row
        .mini-stat
          span.mini-val#peakTime —
          span.mini-label Busiest Hour
        .mini-stat
          span.mini-val#quietDay —
          span.mini-label Quietest Day
        .mini-stat
          span.mini-val#totalRecords —
          span.mini-label Check-ins Analyzed

      //- ── LOW DATA WARNING ────────────────────────────────
      .low-data-banner.hidden#lowDataBanner
        span ⚠️
        span Predictions improve as more members use check-in. Currently limited data.

block scripts
  script(src="/js/congestion.js")
