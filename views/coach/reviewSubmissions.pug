extends ../base

block styles
  link(rel="stylesheet" href="/css/reviewSubmissions.css")

block content
  .top-bar
    a.dashboard-btn(href="/coachDashboard") Dashboard
    a.back-btn(href="javascript:history.back()") Back

  .page-header
    h1 Challenge Submissions
    p.page-subtitle Reviewing as &nbsp;
      span.coach-name #{user.username}

  .submissions-wrapper
    if !submissions || submissions.length === 0
      .empty-state
        p.empty-icon 📋
        p No submissions yet for this challenge.
    else
      each log in submissions
        .submission-card
          p.error-message

          .submission-header
            .submission-user
              .user-avatar
                if log.userId && log.userId.pfpUrl
                  img(src=log.userId.pfpUrl alt="Profile Picture" style="width:48px;height:48px;border-radius:50%;object-fit:cover;display:block;")
                else
                  | #{log.userId && log.userId.username ? log.userId.username[0].toUpperCase() : '?'}
              .user-info
                h3= log.userId && log.userId.username ? log.userId.username : 'Unknown User'
                if log.judgeStatus === "approved"
                  span.status-badge.status-approved ✔ Approved
                else if log.judgeStatus === "rejected"
                  span.status-badge.status-rejected ✘ Rejected
                else
                  span.status-badge.status-pending ⏳ Pending Review
          .submission-body
            .exercises-col
              h4.section-label 📊 Exercises & Sets
              if log.exercises && log.exercises.length
                each ex in log.exercises
                  .exercise-block
                    .exercise-block-header
                      span.ex-name= ex.name
                      span.ex-target= ex.target
                    if ex.set && ex.set.length
                      table
                        thead
                          tr
                            th Set
                            th Weight
                            th Reps
                        tbody
                          - let wi = 0;
                          each s in ex.set
                            if s.type !== "warmup"
                              - wi++;
                              tr
                                td= wi
                                td #{s.weight || '—'} #{s.unit || ''}
                                td= s.reps || '—'
                    else
                      p.no-data No sets recorded.
              else
                p.no-data No exercises submitted.

            .video-col
              h4.section-label 🎥 Submission Video
              if log.videoUrl
                video(controls)
                  source(src=log.videoUrl type="video/mp4")
              else
                .no-video
                  span 🚫
                  p No video submitted

          if log.judgeStatus === "pending"
            form.verify-form(
              data-log-id=log._id
              action=`/api/v1/workout-logs/${log._id}/verify`
              method="POST"
            )
              .form-section
                label.form-label(for="judgeNotes") Coach Notes
                textarea(
                  name="judgeNotes"
                  rows="3"
                  placeholder="Enter feedback for the athlete..."
                )
              .form-actions
                button.btn-approve(type="submit" name="decision" value="approved") ✔ Approve
                button.btn-reject(type="submit" name="decision" value="rejected") ✘ Reject
          else
            .reviewed-block
              p.reviewed-text ✔ This submission has already been reviewed.
              if log.judgeNotes
                .coach-notes
                  span.notes-label Coach Notes:
                  p= log.judgeNotes

block scripts
  script(src="/js/reviewSubmissions.js")
