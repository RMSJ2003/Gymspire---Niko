extends base

block styles
  style.
    @import url("https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700;800&display=swap");

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: "DM Sans", Arial, sans-serif;
      background: #f4f4f5;
      color: #1a1a1a;
      min-height: 100vh;
    }

    .top-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 56px;
      background: linear-gradient(135deg, #d25353, #b11226);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.2rem;
      z-index: 1000;
      box-shadow: 0 2px 16px rgba(177, 18, 38, 0.35);
    }
    .top-bar a {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      padding: 0.38rem 0.9rem;
      border-radius: 7px;
      font-weight: 700;
      font-size: 0.8rem;
      text-decoration: none;
      color: white;
      background: rgba(255, 255, 255, 0.15);
      border: 1px solid rgba(255, 255, 255, 0.22);
      transition: 0.18s;
    }
    .top-bar a:hover {
      background: rgba(255, 255, 255, 0.28);
      color: #f4c430;
    }

    .edit-profile-page {
      min-height: 100vh;
      padding: 80px 1rem 3rem;
      display: flex;
      align-items: flex-start;
      justify-content: center;
    }

    .edit-card {
      background: white;
      border-radius: 20px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
      border: 1px solid rgba(210, 83, 83, 0.1);
      overflow: hidden;
    }

    .edit-card__header {
      background: linear-gradient(135deg, #d25353, #b11226);
      padding: 1.4rem 1.8rem 1.2rem;
      text-align: center;
    }
    .edit-card__header h1 {
      font-family: "Bebas Neue", sans-serif;
      font-size: 2rem;
      letter-spacing: 0.06em;
      color: white;
    }

    .edit-avatar-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      padding: 1.5rem 1.8rem 0.5rem;
    }
    .edit-profile-pic {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid #d25353;
      box-shadow: 0 0 0 5px rgba(210, 83, 83, 0.12);
      transition: opacity 0.2s;
    }
    .avatar-change-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 0.4rem 1rem;
      border-radius: 999px;
      background: rgba(210, 83, 83, 0.08);
      border: 1.5px solid rgba(210, 83, 83, 0.25);
      color: #d25353;
      font-weight: 700;
      font-size: 0.78rem;
      cursor: pointer;
      transition: 0.18s;
    }
    .avatar-change-btn:hover {
      background: rgba(210, 83, 83, 0.14);
      border-color: #d25353;
    }
    .avatar-change-btn svg {
      width: 13px;
      height: 13px;
      stroke: currentColor;
      fill: none;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    form {
      padding: 1.2rem 1.8rem 1.8rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .form-message {
      text-align: center;
      font-size: 0.82rem;
      font-weight: 600;
      color: #d25353;
      min-height: 18px;
    }
    .form-message.success {
      color: #16a34a;
    }

    .form-group {
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    label {
      font-size: 0.75rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.6px;
      color: #aaa;
    }

    input[type="text"] {
      width: 100%;
      padding: 0.65rem 0.85rem;
      border: 1.5px solid #e5e5e5;
      border-radius: 9px;
      background: #fafafa;
      color: #1a1a1a;
      font-family: "DM Sans", sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      outline: none;
      transition: border-color 0.18s, box-shadow 0.18s;
    }
    input[type="text"]:focus {
      border-color: #d25353;
      box-shadow: 0 0 0 3px rgba(210, 83, 83, 0.1);
      background: white;
    }
    input[type="text"]::placeholder {
      color: #ccc;
    }

    .file-group {
      position: relative;
    }
    input[type="file"] {
      position: absolute;
      width: 1px;
      height: 1px;
      opacity: 0;
      overflow: hidden;
      z-index: -1;
    }

    .file-group label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 0.55rem 1rem;
      border-radius: 9px;
      border: 1.5px dashed rgba(210, 83, 83, 0.35);
      background: rgba(210, 83, 83, 0.03);
      color: #d25353;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: 0.18s;
      width: fit-content;
    }
    .file-group label:hover {
      background: rgba(210, 83, 83, 0.07);
      border-color: #d25353;
    }

    .file-hint {
      font-size: 0.72rem;
      color: #bbb;
      font-weight: 500;
      margin-top: 3px;
    }

    button[type="submit"] {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      padding: 0.78rem 1rem;
      border: none;
      border-radius: 11px;
      background: linear-gradient(135deg, #d25353, #b11226);
      color: white;
      font-family: "DM Sans", sans-serif;
      font-weight: 800;
      font-size: 0.9rem;
      cursor: pointer;
      box-shadow: 0 4px 18px rgba(177, 18, 38, 0.28);
      transition: filter 0.2s, transform 0.2s;
      margin-top: 0.2rem;
    }
    button[type="submit"]:hover {
      filter: brightness(1.08);
      transform: translateY(-1px);
    }
    button[type="submit"]:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }
    button[type="submit"] svg {
      width: 15px;
      height: 15px;
      stroke: white;
      fill: none;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      flex-shrink: 0;
    }

    @media (max-width: 480px) {
      .edit-card {
        border-radius: 16px;
      }
      form {
        padding: 1rem 1.2rem 1.5rem;
      }
      .edit-avatar-wrap {
        padding: 1.2rem 1.2rem 0.4rem;
      }
      .edit-profile-pic {
        width: 90px;
        height: 90px;
      }
    }

block content

  .top-bar
    if user.userType === "user"
      a(href='/dashboard') Dashboard
    if user.userType === "coach"
      a(href='/coachDashboard') Dashboard
    if user.userType === "admin"
      a(href='/adminDashboard') Dashboard
    a(href='javascript:history.back()') Back

  .edit-profile-page
    .edit-card

      .edit-card__header
        h1 #{title}

      .edit-avatar-wrap
        if currentUser.pfpUrl
          img.edit-profile-pic#previewImg(src=currentUser.pfpUrl alt="Profile Picture" onerror="this.onerror=null;this.src='/img/default-user.png'")
        else
          img.edit-profile-pic#previewImg(src="/img/default-user.png" alt="Default Profile" onerror="this.onerror=null;this.src='/img/default-user.png'")
        label.avatar-change-btn(for="pfp")
          svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24')
            path(d='M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z')
            circle(cx='12' cy='13' r='4')
          span Change Photo

      form#editProfileForm(enctype="multipart/form-data")
        p.form-message#formMessage

        .form-group
          label(for="username") Username
          input(
            type="text"
            name="username"
            id="username"
            value=currentUser.username
            placeholder="Enter new username"
          )

        .form-group.file-group
          label(for="pfp") Profile Picture
          input(type="file" name="pfp" id="pfp" accept="image/*")
          .file-hint Select an image file (JPG, PNG, GIF)

        button(type="submit")
          svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24')
            path(d='M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z')
            polyline(points='17 21 17 13 7 13 7 21')
            polyline(points='7 3 7 8 15 8')
          span Save Changes

block scripts
  script(src='/js/editProfile.js')
