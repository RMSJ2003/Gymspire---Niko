extends ../base

block styles
  link(rel="stylesheet" href="/css/createChallenge.css")

block content
  //- TOP BAR
  .top-bar
    if user.userType === "user"
      a.dashboard-btn(href='/dashboard') Dashboard
    if user.userType === "coach"
      a.dashboard-btn(href='/coachDashboard') Dashboard
    if user.userType === "admin"
      a.dashboard-btn(href='/adminDashboard') Dashboard
    a.back-btn(href='javascript:history.back()') Back

  //- PAGE HEADER
  .page-header
    h1 #{title}
    h2 #{user.username}

  if user.pfpUrl
    img.profile-pic(src=user.pfpUrl alt="Profile Picture")
  else
    img.profile-pic(src="/img/default-user.png" alt="Default Profile")

  //- CHALLENGE INFO CARD
  .challenge-info-card
    p.card-title Challenge Details

    form#createChallengeForm.hidden
      .field-group
        label(for="name") Challenge Name
        input(type="text" name="name" id="name" placeholder="e.g. Push Day Blitz" required)

      .field-group
        label(for="startTime") Start Time
        input(type="datetime-local" name="startTime" id="startTime" required)

      .field-group
        label(for="endTime") End Time
        input(type="datetime-local" name="endTime" id="endTime" required)

  //- MUSCLE GROUP LABEL
  p.section-label Select exercises per muscle group

  //- TARGET GRID
  .target-grid#targetGrid

  //- SUBMIT
  .update-section
    p.form-message#formMessage
    button(type="submit" form="createChallengeForm") Create Challenge

  //- SPLIT-PANEL TARGET MODAL
  .modal.hidden#targetModal
    .modal-content.large
      .modal-header
        h3#targetTitle
        .modal-header-right
          span.selected-count-badge#selectedCountBadge 0 selected
          button#closeTargetModal(type="button" aria-label="Close") ×

      .modal-split-body
        //- LEFT: live GIF preview
        .modal-preview-panel
          .preview-gif-wrap
            .preview-placeholder#previewPlaceholder
              svg(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5")
                path(stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.25h2.25v13.5H5.25V5.25zm11.25 0h2.25v13.5H16.5V5.25zM8.25 9h7.5v6h-7.5V9z")
              span Hover an exercise
            img.preview-gif#previewGif(alt="Exercise preview")
          p.preview-name#previewName
          span.preview-badge#previewBadge

        //- RIGHT: exercise list
        .modal-list-panel
          .exercise-list#targetExerciseList

  //- DATA
  script#exercisesData(type="application/json").
    !{JSON.stringify(exercises)}

  script.
    window.exercises = JSON.parse(document.getElementById("exercisesData").textContent)

block scripts
  script(src="/js/createChallenge.js")
