extends ../base

block styles
  link(rel="stylesheet" href="/css/createCoach.css")

block content
  // =========================
  // BACK BUTTON
  // =========================
  .back-btn-container
    a.back-btn(href="javascript:history.back()") Back

  // =========================
  // CARD
  // =========================
  .card

    // Logo
    .logo-row
      .logo-icon
        svg(viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg")
          path(d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29z")
      span.logo-text GYM#[span SPIRE]

    .logo-divider

    // Title
    h1.page-title #{title}
    p.page-subtitle Creating as #[strong #{user.username}]

    // Profile picture upload
    label.pfp-upload-wrapper(for="pfp" title="Click to upload profile photo")
      .pfp-circle
        if user.pfpUrl
          img#pfpPreview(src=user.pfpUrl alt="Profile Picture")
        else
          img#pfpPreview(src="/img/default-user.png" alt="Default Profile")
        .pfp-overlay
      span.pfp-upload-label Click to upload profile photo

    // =========================
    // CREATE COACH FORM
    // =========================
    form(id='createCoachForm' novalidate)
      p.form-message#formMessage

      .field-group
        label(for='email') Email
        .input-wrap
          input(type='email' name='email' id='email' placeholder='coach@gymspire.com' required)
        small.form-error#emailError

      .field-group
        label(for='username') Username
        .input-wrap
          input(type='text' name='username' id='username' placeholder='e.g. CoachJuan' required)

      .field-group
        label(for='pfp') Profile Picture
        input(type="file" name="pfp" id="pfp" accept="image/*")

      .field-group
        label(for='password') Password
        .input-wrap
          input(type='password' name='password' id='password' required)
          button.toggle-pw(type='button' aria-label='Show password' onclick='togglePw("password", this)')
            svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
              path(d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z")
              circle(cx="12" cy="12" r="3")
        small.form-error#passwordError

      .field-group
        label(for='passwordConfirm') Confirm Password
        .input-wrap
          input(type='password' name='passwordConfirm' id='passwordConfirm' required)
          button.toggle-pw(type='button' aria-label='Show confirm password' onclick='togglePw("passwordConfirm", this)')
            svg(width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
              path(d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z")
              circle(cx="12" cy="12" r="3")
        small.form-error#passwordConfirmError

      button(type='submit' id='submitBtn')
        span.btn-text Create Coach

block scripts
  script(src='/js/createCoach.js')
  script.
    // PFP live preview
    document.getElementById('pfp').addEventListener('change', function() {
      const file = this.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = e => document.getElementById('pfpPreview').src = e.target.result;
        reader.readAsDataURL(file);
      }
    });

    // Toggle password visibility
    function togglePw(inputId, btn) {
      const input = document.getElementById(inputId);
      const isText = input.type === 'text';
      input.type = isText ? 'password' : 'text';
      btn.style.color = isText ? '' : '#d13b3b';
    }
