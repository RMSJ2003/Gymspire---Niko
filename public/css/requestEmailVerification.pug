extends ../base

block styles
  link(rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap")
  link(rel="stylesheet" href="/css/requestEmailVerification.css")

block content
  section.section-email-verification
    .card

      //- Logo
      .logo-wrapper
        .logo-icon
          svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24')
            path(d='M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2.71 4.14l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43 1.43-1.43-1.43-1.43L22 16.29l-1.43-1.43z')
        .logo-text GYM#[span SPIRE]

      .logo-divider

      //- Envelope icon
      .verify-icon
        svg(xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24')
          path(d='M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z')

      h2 Verify Your Email
      p.subtitle Enter your iACADEMY email and we'll send you a verification link.

      //- Nav links
      .links-row
        a.email-verification__link(href='/login') Login
        span.email-verification__divider |
        a.email-verification__link(href='/signup') Sign up

      //- Form
      form#emailVerificationForm.email-verification__form(novalidate)
        label.email-verification__label(for='email') Email
        input.email-verification__input(
          type='email'
          name='email'
          id='email'
          required
          placeholder='you@iacademy.ph'
        )
        button#submitBtn.email-verification__button(type='submit')
          span.email-verification__button-text.btn-text Send Verification Email

      //- Message
      p.email-verification__message#formMessage

block scripts
  script(src='/js/emailVerification.js')
