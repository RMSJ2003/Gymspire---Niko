extends base

block styles
  link(rel="stylesheet" href="/css/workoutLog.css")

block content
  .top-bar
    if user.userType === "user"
      a(href='/dashboard') Dashboard
    if user.userType === "coach"
      a(href='/coachDashboard') Dashboard
    if user.userType === "admin"
      a(href='/adminDashboard') Dashboard
    a(href='javascript:history.back()') Back

  h1 #{title}
  h2 #{user.username}

  if user.pfpUrl
    img.profile-pic(src=user.pfpUrl alt="Profile Picture")
  else
    img.profile-pic(src="/img/default-user.png" alt="Default Profile")

  h2 Date: #{log.date.toDateString()}
  p Status: #{log.status}

  if log.challengeId
    p Strength Score: #{log.strengthScore >= 0 ? log.strengthScore : "Not calculated yet"}

    if log.judgeNotes
      p Judge Notes: #{log.judgeNotes}
    else
      p Judge Notes: No judge notes yet

    if log.verifiedBy && log.verifiedBy.username
      p Verified by: #{log.verifiedBy.username}
    else
      p Verified by: Not verified yet

    if log.videoUrl
      p Video:
      video(src=log.videoUrl controls preload="metadata" style="max-width:100%; margin-top:8px;")
    else
      p Video: No video submitted

  if log.challengeId
    p Type: Challenge Workout
  else
    p Type: Solo Workout

  if log.exercises && log.exercises.length
    h3 Exercises Performed

    -
      // Build a lookup: exName -> setNumber -> { weight, reps }
      // from the most recent previous log that contains this exercise
      const prevLookup = {};
      if (prevLog && prevLog.length) {
        // prevLog is sorted newest-first from backend, skip current log
        const prev = prevLog.find(l => l._id.toString() !== log._id.toString() && l.status === "done");
        if (prev && prev.exercises) {
          prev.exercises.forEach(ex => {
            if (!prevLookup[ex.name]) prevLookup[ex.name] = {};
            let wIdx = 0;
            ex.set.forEach(s => {
              if (s.type === "working") {
                wIdx++;
                prevLookup[ex.name][wIdx] = { weight: s.weight, reps: s.reps, unit: s.unit };
              }
            });
          });
        }
      }

    each ex in log.exercises
      .exercise-card
        h4= ex.name
        p Target: #{ex.target}

        if ex.gifURL
          img(src=ex.gifURL alt=ex.name width="200")

        if ex.set && ex.set.length
          table
            thead
              tr
                th Set #
                th Weight
                th Reps
                th(style="min-width:120px") Action

            tbody
              - let workingIndex = 0;

              each s in ex.set
                if s.type !== "warmup"
                  - workingIndex++;
                  - const prev = prevLookup[ex.name] && prevLookup[ex.name][workingIndex];

                  if log.status === "done"
                    tr
                      td= workingIndex
                      td #{s.weight} #{s.unit}
                      td= s.reps
                      td ✓
                  else
                    tr(
                      data-set-id=s._id
                      data-prev-weight=prev ? prev.weight : ""
                      data-prev-reps=prev ? prev.reps : ""
                      data-prev-unit=prev ? (prev.unit || "LB") : ""
                    )
                      td= workingIndex
                      td.weight-cell(
                        data-init-weight=s.weight || 0
                        data-unit=s.unit || 'LB'
                      )
                      td.reps-cell(
                        data-init-reps=Math.min(12, Math.max(8, s.reps || 8))
                      )
                      td.action-cell

    if log.status !== "done"
      button#saveSetsBtn(data-log-id=log._id style="display:none") Save Working Sets
      p#setMessage

    if log.status !== "done"
      input(
        type="file"
        accept="video/*"
        class="video-input"
        data-log-id=log._id
        style="display:none"
      )
      button#finish-btn(
        data-log-id=log._id
        data-is-challenge=log.challengeId ? "true" : "false"
      ) Finish Workout

block scripts
  script(src="/js/workoutLog.js")
