extends base

block styles
  link(rel="stylesheet" href="/css/workoutPlan.css")

block content
  .top-bar
    if user.userType === "user"
      a.dashboard-btn(href='/dashboard') Dashboard
    if user.userType === "coach"
      a.dashboard-btn(href='/coachDashboard') Dashboard
    if user.userType === "admin"
      a.dashboard-btn(href='/adminDashboard') Dashboard
    a.back-btn(href='javascript:history.back()') Back

  - const safeUser = user || { username: "Guest", pfpUrl: null }
  - const planExists = typeof hasPlan !== "undefined" ? hasPlan : false
  - const exerciseList = exercises || []

  .page-header
    .page-header-inner
      if safeUser.pfpUrl
        img.profile-pic(src=safeUser.pfpUrl alt="Profile Picture")
      else
        img.profile-pic(src="/img/default-user.png" alt="Default Profile")
      .page-header-text
        h1 Workout Plan
        p.header-username #{safeUser.username}
    if planExists
      a.btn(href='/editWorkoutPlan') ✏️ Edit Plan
    else
      a.btn.btn-create(href='/createWorkoutPlan') ➕ Create Plan

  .plan-wrapper
    if !planExists
      .empty-state
        p.empty-icon 📋
        p You don't have a workout plan yet.
        a.btn.btn-create(href='/createWorkoutPlan') ➕ Create Workout Plan

    else if exerciseList.length === 0
      .empty-state
        p.empty-icon 🏋️
        p No exercises in your workout plan yet.
        a.btn(href='/editWorkoutPlan') ✏️ Edit Plan

    else
      p.exercise-count #{exerciseList.length} exercise#{exerciseList.length !== 1 ? 's' : ''} in your plan

      .exercises-grid
        each exercise in exerciseList
          .exercise-card
            .exercise-card-top
              if exercise.gifURL
                img.exercise-gif(src=exercise.gifURL alt=exercise.name)
              .exercise-info
                h3= exercise.name || "Unnamed Exercise"
                span.exercise-target= exercise.target || "N/A"
            if exercise.instructions && exercise.instructions.length
              details.exercise-steps
                summary View Instructions
                ol
                  each step in exercise.instructions
                    li= step
