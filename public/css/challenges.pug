extends base

block styles
  link(rel="stylesheet", href="/css/challenges.css")

block content
  .top-bar
    if user.userType === "user"
      a.dashboard-btn(href='/dashboard') Dashboard
    if user.userType === "coach"
      a.dashboard-btn(href='/coachDashboard') Dashboard
    if user.userType === "admin"
      a.dashboard-btn(href='/adminDashboard') Dashboard
    a.back-btn(href='javascript:history.back()') Back

  .page-header
    .page-header-inner
      if user.pfpUrl
        img.profile-pic(src=user.pfpUrl alt="Profile Picture")
      else
        img.profile-pic(src="/img/default-user.png" alt="Default Profile")
      .page-header-text
        h1 Challenges
        p.header-username #{user.username}
    if user.userType === "coach"
      a.create-challenge(href='/createChallenge') + Create Challenge

  .challenges-wrapper
    if challenges.length === 0
      .empty-state
        p.empty-icon 🏋️
        p No challenges available yet.
    else
      each challenge in challenges
        .challenge-card
          .challenge-card-header
            h2= challenge.name
            .challenge-meta
              span.meta-item 📅 #{challenge.startTime.toDateString()} — #{challenge.endTime.toDateString()}
              span.meta-item 👥 #{challenge.participants.length} participant#{challenge.participants.length !== 1 ? 's' : ''}

          if challenge.participants.length
            .participants-row
              each p in challenge.participants
                .participant
                  if p.pfpUrl
                    img(src=p.pfpUrl alt=p.username title=p.username)
                  else
                    img(src="/img/default-user.png" alt=p.username title=p.username)
                  span= p.username

          - const alreadyJoined = challenge.participants.some(p => p._id.toString() === user._id.toString())

          .challenge-actions
            if user.userType === 'user'
              if alreadyJoined
                span.join-status ✔ Joined
              else
                button.join-btn(data-join-code=challenge.joinCode) Join Challenge

            if alreadyJoined
              button.start-btn(data-challenge-id=challenge._id) ▶ Start

            button.leaderboard-btn(data-challenge-id=challenge._id) 🏆 Leaderboard

            if user.userType === 'coach'
              a.review-link(href=`/reviewSubmissions/${challenge._id}`) 📋 Review Submissions

          .leaderboard-container(id=`leaderboard-${challenge._id}` style="display:none;")

          if challenge.exerciseDetails && challenge.exerciseDetails.length
            .exercises-section
              h3 Exercises
              .exercises-grid
                each exercise in challenge.exerciseDetails
                  .exercise-card
                    .exercise-card-top
                      if exercise.gifURL
                        img.exercise-gif(src=exercise.gifURL alt=exercise.name)
                      .exercise-info
                        h4= exercise.name
                        span.exercise-target= exercise.target
                    if exercise.instructions && exercise.instructions.length
                      details.exercise-steps
                        summary View Steps
                        ol
                          each step in exercise.instructions
                            li= step

  p#joinMessage

  block scripts
    script(src="/js/challenges.js")
