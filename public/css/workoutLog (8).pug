extends base

block styles
  link(rel="stylesheet" href="/css/workoutLog.css")

block content
  .top-bar
    if user.userType === "user"
      a(href='/dashboard') Dashboard
    if user.userType === "coach"
      a(href='/coachDashboard') Dashboard
    if user.userType === "admin"
      a(href='/adminDashboard') Dashboard
    a(href='javascript:history.back()') Back

  -
    let consecutiveWeeks = 0;
    let shouldDeload = false;
    let deloadWeeks = 0;

    if (prevLog && prevLog.length) {
      function getWeekKey(date) {
        const d = new Date(date);
        const day = d.getUTCDay();
        const diff = (day === 0 ? -6 : 1) - day;
        d.setUTCDate(d.getUTCDate() + diff);
        return `${d.getUTCFullYear()}-${d.getUTCMonth()}-${d.getUTCDate()}`;
      }
      const weekSet = new Set();
      prevLog.forEach(l => { if (l.status === "done") weekSet.add(getWeekKey(l.date)); });
      weekSet.add(getWeekKey(log.date));
      const weeks = Array.from(weekSet).sort();
      let streak = 1;
      for (let i = weeks.length - 1; i > 0; i--) {
        const curr = weeks[i].split("-").map(Number);
        const prev2 = weeks[i - 1].split("-").map(Number);
        const currDate = new Date(Date.UTC(curr[0], curr[1], curr[2]));
        const prevDate = new Date(Date.UTC(prev2[0], prev2[1], prev2[2]));
        const diffDays = (currDate - prevDate) / (1000 * 60 * 60 * 24);
        if (diffDays === 7) { streak++; } else { break; }
      }
      consecutiveWeeks = streak;
      shouldDeload = streak >= 4;
      deloadWeeks = streak;
    }

  //- ═══════════════════════════════════════
  //- HERO HEADER
  //- ═══════════════════════════════════════
  .workout-hero
    .workout-hero-bg

    .workout-hero-inner
      //- Left: avatar + user info
      .hero-identity
        .hero-avatar-wrap
          if user.pfpUrl
            img.hero-avatar(src=user.pfpUrl alt="Profile Picture")
          else
            img.hero-avatar(src="/img/default-user.png" alt="Default Profile")
          - const isOngoing = log.status === "ongoing"
          span.hero-status-dot(class=isOngoing ? "dot-live" : "dot-done")

        .hero-user-info
          span.hero-username= user.username
          span.hero-date= log.date.toDateString()

      //- Right: stat pills
      .hero-stats
        .hero-stat-pill
          span.pill-label TYPE
          span.pill-value= log.challengeId ? "🏆 Challenge" : "🏋️ Solo"

        .hero-stat-pill
          span.pill-label STATUS
          if log.status === "ongoing"
            span.pill-value.pill-live ● LIVE
          else
            span.pill-value.pill-done ✓ Done

        if log.challengeId && log.strengthScore >= 0
          .hero-stat-pill
            span.pill-label SCORE
            span.pill-value= log.strengthScore > 0 ? log.strengthScore.toFixed(1) : "—"

        if log.challengeId
          .hero-stat-pill
            span.pill-label JUDGE
            if log.judgeStatus === "approved"
              span.pill-value.pill-approved ✓ Approved
            else if log.judgeStatus === "rejected"
              span.pill-value.pill-rejected ✗ Rejected
            else
              span.pill-value.pill-pending ⏳ Pending

  //- ═══════════════════════════════════════
  //- CHALLENGE DETAIL CARD (if challenge)
  //- ═══════════════════════════════════════
  if log.challengeId
    .challenge-detail-card
      if log.judgeNotes
        .detail-row
          span.detail-label 📋 Judge Notes
          span.detail-value= log.judgeNotes
      else
        .detail-row
          span.detail-label 📋 Judge Notes
          span.detail-value.muted No notes yet

      if log.verifiedBy && log.verifiedBy.username
        .detail-row
          span.detail-label ✅ Verified by
          span.detail-value= log.verifiedBy.username
      else
        .detail-row
          span.detail-label ✅ Verified by
          span.detail-value.muted Not verified yet

      if log.videoUrl
        .detail-row.detail-row-video
          span.detail-label 🎥 Video
          video(src=log.videoUrl controls preload="metadata")
      else
        .detail-row
          span.detail-label 🎥 Video
          span.detail-value.muted No video submitted

  //- ═══════════════════════════════════════
  //- DELOAD BANNER
  //- ═══════════════════════════════════════
  if shouldDeload
    .deload-banner
      .deload-banner-icon 🔄
      .deload-banner-body
        strong Deload Week Recommended
        p You've trained <strong>#{deloadWeeks} consecutive weeks</strong>. Your body needs recovery to keep progressing. Consider a deload this week.
        ul.deload-tips
          li Reduce weight by <strong>40–50%</strong> on all exercises
          li Keep the same sets and rep range
          li Focus on <strong>form and mind-muscle connection</strong>
          li Avoid pushing to failure this week
        button.deload-dismiss(type="button") Dismiss

  //- ═══════════════════════════════════════
  //- EXERCISES
  //- ═══════════════════════════════════════
  if log.exercises && log.exercises.length
    .exercises-label Exercises

    -
      const prevLookup = {};
      if (prevLog && prevLog.length) {
        const prev = prevLog.find(l => l._id.toString() !== log._id.toString() && l.status === "done");
        if (prev && prev.exercises) {
          prev.exercises.forEach(ex => {
            if (!prevLookup[ex.name]) prevLookup[ex.name] = {};
            let wIdx = 0;
            ex.set.forEach(s => {
              if (s.type === "working") {
                wIdx++;
                prevLookup[ex.name][wIdx] = { weight: s.weight, reps: s.reps, unit: s.unit };
              }
            });
          });
        }
      }

    each ex, exIndex in log.exercises
      .exercise-card(data-ex-index=exIndex)
        h4= ex.name
        p Target: #{ex.target}

        if ex.gifURL
          img(src=ex.gifURL alt=ex.name width="200")

        if ex.set && ex.set.length
          table
            thead
              tr
                th Set #
                th Weight
                th Reps
                th(style="min-width:120px") Action

            tbody
              - let workingIndex = 0;

              each s in ex.set
                if s.type !== "warmup"
                  - workingIndex++;
                  - const prev = prevLookup[ex.name] && prevLookup[ex.name][workingIndex];

                  if log.status === "done"
                    tr
                      td= workingIndex
                      td #{s.weight} #{s.unit}
                      td= s.reps
                      td ✓
                  else
                    tr(
                      data-set-id=s._id
                      data-saved=s.weight && s.weight > 0 ? "true" : "false"
                      data-prev-weight=prev ? prev.weight : ""
                      data-prev-reps=prev ? prev.reps : ""
                      data-prev-unit=prev ? (prev.unit || "LB") : ""
                    )
                      td.set-num-cell= workingIndex
                      td.weight-cell(
                        data-init-weight=s.weight || 0
                        data-unit=s.unit || 'LB'
                      )
                      td.reps-cell(
                        data-init-reps=s.reps || 8
                      )
                      td.action-cell

        if log.status !== "done"
          .add-set-row
            button.add-set-btn(
              type="button"
              data-log-id=log._id
              data-ex-index=exIndex
            ) + Add Set

    if log.status !== "done"
      button#saveSetsBtn(data-log-id=log._id style="display:none") Save Working Sets
      p#setMessage

    if log.status !== "done"
      input(
        type="file"
        accept="video/*"
        class="video-input"
        data-log-id=log._id
        style="display:none"
      )
      button#finish-btn(
        data-log-id=log._id
        data-is-challenge=log.challengeId ? "true" : "false"
      ) Finish Workout

block scripts
  script(src="/js/workoutLog.js")
